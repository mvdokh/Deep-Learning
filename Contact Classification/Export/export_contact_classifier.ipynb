{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Contact classifier AOT export\n",
        "\n",
        "This notebook exports the trained contact classifier checkpoint to a Torch 2.x AOTInductor `.pt2` artifact.\n",
        "\n",
        "You can choose between:\n",
        "- **Dynamic batch size**: one exported program that accepts variable batch sizes.\n",
        "- **Static batch size**: export specialized to a fixed batch size.\n",
        "\n",
        "The heavy lifting is implemented in `export_contact_classifier.py` so this notebook stays minimal and reproducible."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "tags": []
      },
      "outputs": [],
      "source": [
        "import os\n",
        "from pathlib import Path\n",
        "\n",
        "import torch\n",
        "\n",
        "from export_contact_classifier import export_contact_classifier_aot\n",
        "\n",
        "project_root = Path(\"..\").resolve()\n",
        "print(f\"Project root: {project_root}\")\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "device"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Configure paths\n",
        "\n",
        "Update these if you move the checkpoint or want to change the export location/name."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "checkpoint_path = project_root / \"Training\" / \"checkpoints\" / \"contact_classifier_WORKING.pt\"\n",
        "export_dir = project_root / \"Export\" / \"artifacts\"\n",
        "export_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "export_name_dynamic = \"contact_classifier_dynamic.pt2\"\n",
        "export_name_static = \"contact_classifier_static_bs1.pt2\"\n",
        "\n",
        "print(\"Checkpoint:\", checkpoint_path)\n",
        "print(\"Export dir:\", export_dir)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Choose export mode\n",
        "\n",
        "Set `USE_DYNAMIC_BATCH` to `True` for a single exported program that accepts a range of batch sizes.\n",
        "\n",
        "If `False`, a static batch size export will be created instead."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "USE_DYNAMIC_BATCH = True  # set to False for static batch export\n",
        "\n",
        "IMG_SIZE = 256\n",
        "CHANNELS = 3\n",
        "\n",
        "# Static batch configuration\n",
        "STATIC_BATCH_SIZE = 1\n",
        "\n",
        "# Dynamic batch configuration\n",
        "DYNAMIC_MIN_BATCH = 1\n",
        "DYNAMIC_MAX_BATCH = 32"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Run export\n",
        "\n",
        "This cell calls the helper in `export_contact_classifier.py` and writes the `.pt2` file."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "if not checkpoint_path.is_file():\n",
        "    raise FileNotFoundError(f\"Checkpoint not found: {checkpoint_path}\")\n",
        "\n",
        "if USE_DYNAMIC_BATCH:\n",
        "    export_path = export_dir / export_name_dynamic\n",
        "    print(\"Exporting with dynamic batch dimension →\", export_path)\n",
        "    out_path = export_contact_classifier_aot(\n",
        "        checkpoint_path=checkpoint_path,\n",
        "        export_path=export_path,\n",
        "        device=device,\n",
        "        img_size=IMG_SIZE,\n",
        "        channels=CHANNELS,\n",
        "        dynamic_batch=True,\n",
        "        dynamic_min_batch=DYNAMIC_MIN_BATCH,\n",
        "        dynamic_max_batch=DYNAMIC_MAX_BATCH,\n",
        "    )\n",
        "else:\n",
        "    export_path = export_dir / export_name_static\n",
        "    print(\"Exporting with static batch size →\", export_path)\n",
        "    out_path = export_contact_classifier_aot(\n",
        "        checkpoint_path=checkpoint_path,\n",
        "        export_path=export_path,\n",
        "        device=device,\n",
        "        img_size=IMG_SIZE,\n",
        "        channels=CHANNELS,\n",
        "        static_batch_size=STATIC_BATCH_SIZE,\n",
        "        dynamic_batch=False,\n",
        "    )\n",
        "\n",
        "print(\"Saved exported program to:\", out_path)\n",
        "out_path"
      ]
    }
  ],
  "metadata": {
    "kernelspec": {
      "display_name": "Python 3",
      "language": "python",
      "name": "python3"
    },
    "language_info": {
      "name": "python",
      "version": "3.12"
    }
  },
  "nbformat": 4,
  "nbformat_minor": 5
},
